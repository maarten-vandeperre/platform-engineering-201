# Workshop configuration
# Copy to workshop.env and customize, then: source scripts/workshop.env

# OpenShift project/namespace for the workshop
export WORKSHOP_NAMESPACE="${WORKSHOP_NAMESPACE:-maarten-vandeperre-dev}"

# Git repository used by Argo CD and catalog entities
export WORKSHOP_GIT_REPO="${WORKSHOP_GIT_REPO:-https://github.com/maarten-vandeperre/platform-engineering-201.git}"
export WORKSHOP_GIT_BRANCH="${WORKSHOP_GIT_BRANCH:-main}"

# GitHub organization/user for catalog annotations and image registry
export WORKSHOP_GITHUB_ORG="${WORKSHOP_GITHUB_ORG:-maarten-vandeperre}"
export WORKSHOP_GITHUB_REPO="${WORKSHOP_GITHUB_REPO:-platform-engineering-201}"

# Container images — defaults use OpenShift ImageStreams built by scripts/build-images-openshift.sh
export WORKSHOP_IMAGE_REGISTRY="${WORKSHOP_IMAGE_REGISTRY:-image-registry.openshift-image-registry.svc:5000/${WORKSHOP_NAMESPACE}}"
export WORKSHOP_BACKEND_IMAGE="${WORKSHOP_BACKEND_IMAGE:-${WORKSHOP_IMAGE_REGISTRY}/people-backend:latest}"
export WORKSHOP_FRONTEND_IMAGE="${WORKSHOP_FRONTEND_IMAGE:-${WORKSHOP_IMAGE_REGISTRY}/people-frontend:latest}"

# Developer Hub instance name and route host suffix (auto-detected when empty)
export RHDH_NAMESPACE="${RHDH_NAMESPACE:-${WORKSHOP_NAMESPACE}}"
export RHDH_INSTANCE_NAME="${RHDH_INSTANCE_NAME:-developer-hub}"
export RHDH_APP_TITLE="${RHDH_APP_TITLE:-Nile Developer Hub}"

# OpenShift GitOps / Argo CD
export GITOPS_NAMESPACE="${GITOPS_NAMESPACE:-${WORKSHOP_NAMESPACE}}"
export ARGOCD_INSTANCE_NAME="${ARGOCD_INSTANCE_NAME:-workshop-gitops}"
export ARGOCD_APP_NAME="${ARGOCD_APP_NAME:-people-service}"

# PostgreSQL credentials for the demo app
export PEOPLE_DB_NAME="${PEOPLE_DB_NAME:-people}"
export PEOPLE_DB_USER="${PEOPLE_DB_USER:-people}"
export PEOPLE_DB_PASSWORD="${PEOPLE_DB_PASSWORD:-people}"

# Keycloak identity provider
export KEYCLOAK_ADMIN_USER="${KEYCLOAK_ADMIN_USER:-admin}"
export KEYCLOAK_ADMIN_PASSWORD="${KEYCLOAK_ADMIN_PASSWORD:-r3dh@t}"
export KEYCLOAK_REALM="${KEYCLOAK_REALM:-workshop}"
export KEYCLOAK_CLIENT_ID="${KEYCLOAK_CLIENT_ID:-people-service}"
export OIDC_ENABLED="${OIDC_ENABLED:-true}"
# Populated automatically by scripts/setup-keycloak.sh when empty
export KEYCLOAK_URL="${KEYCLOAK_URL:-}"
export OIDC_AUTH_SERVER_URL="${OIDC_AUTH_SERVER_URL:-}"

# Developer Hub Keycloak SSO
export RHDH_KEYCLOAK_CLIENT_ID="${RHDH_KEYCLOAK_CLIENT_ID:-developer-hub}"
export RHDH_KEYCLOAK_CLIENT_SECRET="${RHDH_KEYCLOAK_CLIENT_SECRET:-developer-hub-workshop-secret}"
export RHDH_KEYCLOAK_USER="${RHDH_KEYCLOAK_USER:-devhub}"
export RHDH_KEYCLOAK_PASSWORD="${RHDH_KEYCLOAK_PASSWORD:-r#dh@t}"
export RHDH_OIDC_CLIENT_SECRET="${RHDH_OIDC_CLIENT_SECRET:-${RHDH_KEYCLOAK_CLIENT_SECRET}}"
export WORKSHOP_CATALOG_URL="${WORKSHOP_CATALOG_URL:-}"

# Developer Hub external notifications (People API -> POST /api/notifications/notifications)
export BACKEND_SECRET="${BACKEND_SECRET:-workshop-backend-secret}"
export PEOPLE_NOTIFICATION_TOKEN="${PEOPLE_NOTIFICATION_TOKEN:-${BACKEND_SECRET}}"

# Helm installs (alternative to operators)
export CLUSTER_ROUTER_BASE="${CLUSTER_ROUTER_BASE:-apps.example.com}"
export ARGOCD_ROUTE_HOST="${ARGOCD_ROUTE_HOST:-argocd-${WORKSHOP_NAMESPACE}.${CLUSTER_ROUTER_BASE}}"
export ARGOCD_INSTALL_CRDS="${ARGOCD_INSTALL_CRDS:-true}"
export ARGOCD_ADMIN_PASSWORD="${ARGOCD_ADMIN_PASSWORD:-admin123!}"
export RHDH_HELM_CHART="${RHDH_HELM_CHART:-https://github.com/openshift-helm-charts/charts/releases/download/redhat-redhat-developer-hub-1.9.3/redhat-developer-hub-1.9.3.tgz}"

# GitHub PAT for Developer Hub integrations (repo + workflow read scopes)
# Required for scaffolder publish:github. Configure with ./scripts/setup-github-auth.sh
export GITHUB_TOKEN="${GITHUB_TOKEN:-changeme}"

# GitHub OAuth App for the GitHub Actions CI tab (Authorize GitHub popup)
# Create at https://github.com/settings/applications/new
# Callback URL: https://redhat-developer-hub-<namespace>.<router>/api/auth/github/handler/frame
export AUTH_GITHUB_CLIENT_ID="${AUTH_GITHUB_CLIENT_ID:-changeme}"
export AUTH_GITHUB_CLIENT_SECRET="${AUTH_GITHUB_CLIENT_SECRET:-changeme}"

# Bootstrap behaviour: operator | helm | skip-platform
export WORKSHOP_INSTALL_METHOD="${WORKSHOP_INSTALL_METHOD:-operator}"
export SKIP_ARGOCD="${SKIP_ARGOCD:-false}"
export RUN_E2E="${RUN_E2E:-false}"

# Kogito Data Index image for standalone Orchestrator fallback (when Serverless Logic is absent).
# Must match the RHDH Orchestrator plugin GraphQL schema (requires executionSummary on ProcessInstance).
# Use OpenShift Serverless Logic 1.36+ image; legacy quay.io/kiegroup/...:latest and 1.35.0 break "All runs".
export ORCHESTRATOR_DATA_INDEX_IMAGE="${ORCHESTRATOR_DATA_INDEX_IMAGE:-registry.redhat.io/openshift-serverless-1/logic-data-index-postgresql-rhel8:1.36.0}"

export AAP_ADMIN_USERNAME="changeme"
export AAP_ADMIN_PASSWORD="changeme"